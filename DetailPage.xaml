<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimeApp.DetailPage"
             Title="Details"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="600" HorizontalOptions="Center">

            <VerticalStackLayout HorizontalOptions="Center" Margin="0,20,0,20">
                <Label x:Name="DaysLabel" Text="5" FontSize="100" FontAttributes="Bold" TextColor="#3F51B5" HorizontalOptions="Center" />
                <Label x:Name="EventTitleLabel" Text="Days Left" FontSize="18" TextColor="Gray" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Label Text="Memos" FontAttributes="Bold" FontSize="22" TextColor="#333333" Margin="0,10,0,0"/>

            <Grid ColumnDefinitions="4, *">
                <BoxView Grid.Column="0" BackgroundColor="#FF4081" CornerRadius="2" Margin="0,5"/>
                <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="15" Margin="15,0,0,0" HasShadow="False" BorderColor="#E0E0E0">
                    <VerticalStackLayout>
                        <Label Text="Bought a cake today. Need to pick it up at 3 PM." FontSize="16" TextColor="#333333"/>
                        <Label Text="Oct 19, 10:00 AM" FontSize="12" TextColor="Gray" Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Grid ColumnDefinitions="4, *">
                <BoxView Grid.Column="0" BackgroundColor="#FF4081" CornerRadius="2" Margin="0,5"/>
                <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="15" Margin="15,0,0,0" HasShadow="False" BorderColor="#E0E0E0">
                    <VerticalStackLayout>
                        <Label Text="Thinking about buying that necklace." FontSize="16" TextColor="#333333"/>
                        <Label Text="Oct 15, 08:30 PM" FontSize="12" TextColor="Gray" Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage> 