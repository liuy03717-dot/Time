<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimeApp.DetailPage"
             Title="Details"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="600" HorizontalOptions="Center">

            <VerticalStackLayout HorizontalOptions="Center" Margin="0,20,0,20">
                <Label x:Name="DaysLabel" FontSize="100" FontAttributes="Bold" TextColor="#3F51B5" HorizontalOptions="Center" />
                <Label x:Name="EventTitleLabel" FontSize="18" TextColor="Gray" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Label Text="Memos" FontAttributes="Bold" FontSize="22" TextColor="#333333" Margin="0,10,0,10"/>

            <Grid ColumnDefinitions="30, *">
                <BoxView Grid.Column="0" WidthRequest="2" BackgroundColor="#E0E0E0" HorizontalOptions="Center" VerticalOptions="Fill" />

                <Grid Grid.Column="1" ColumnDefinitions="Auto, *">
                    <Ellipse WidthRequest="12" HeightRequest="12" Fill="#FF4081" Margin="-36,20,0,0" VerticalOptions="Start" />
                    <Frame BackgroundColor="White" CornerRadius="12" Padding="15" Margin="0,0,0,15" HasShadow="False" BorderColor="#E0E0E0">
                        <VerticalStackLayout>
                            <Label Text="Created this event to track progress." FontSize="16" TextColor="#333333"/>
                            <Label Text="Today, 10:00 AM" FontSize="12" TextColor="Gray" Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
